			message: '#^Method Aeliot\\PHPUnitCodeCoverageBaseline\\Enum\\Version\:\:__unserialize\(\) has parameter \$data with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: ../../../src/Enum/Version.php

		-
			message: '#^Method Aeliot\\PHPUnitCodeCoverageBaseline\\Reader\\BaselineReaderInterface\:\:read\(\) has no return type specified\.$#'
			identifier: missingType.return
			count: 1
			path: ../../../src/Reader/BaselineReaderInterface.php

		-
			message: '#^Return type of call to method PHPUnit\\Framework\\TestCase\:\:createMock\(\) contains unresolvable type\.$#'
			identifier: method.unresolvableReturnType
