			path: ../../../tests/unit/Reader/BaselineTransformingReaderTest.php

		-
			message: '#^Call to function method_exists\(\) with ''PHPUnit\\\\Framework\\\\TestCase'' and ''expectExceptionMess…'' will always evaluate to true\.$#'
